{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zerothguard.local/schemas/incident.schema.json",
  "title": "Zeroth Guard Incident",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "type": { "type": "string", "const": "incident" },

    "incident_id": { "type": "string", "minLength": 1 },
    "asset_id": { "type": "string", "minLength": 1 },
    "subnet_id": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },

    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },

    "title": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["open", "auto_mitigating", "verified", "resolved", "false_positive"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },

    "policy_disposition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "disposition": { "type": "string", "enum": ["alert", "ask", "act"] },
        "policy_rule_id": { "type": "string", "minLength": 1 },
        "justification": { "type": "string", "minLength": 1 }
      },
      "required": ["disposition", "policy_rule_id", "justification"]
    },

    "findings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "List of finding IDs or refs associated with this incident."
    },

    "evidence_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_ref" }
    }
  },
  "$defs": {
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "minLength": 1 }
      },
      "required": ["kind", "ref"]
    }
  },
  "required": [
    "schema_version",
    "type",
    "incident_id",
    "asset_id",
    "subnet_id",
    "trace_id",
    "created_at",
    "updated_at",
    "title",
    "status",
    "risk_level",
    "confidence",
    "policy_disposition",
    "findings"
  ]
}

